{
  "name": "replicafuzz",
  "version": "0.1.0-alpha.1",
  "private": false,
  "description": "Falsify multi-client browser convergence with seeded schedules and minimized replay",
  "type": "module",
  "bin": {
    "replicafuzz": "./dist/src/cli.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/build-yjs-fixture.mjs && node scripts/copy-release-assets.mjs",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --maxWorkers=1",
    "test:browser": "tsx src/cli.ts smoke",
    "replicafuzz": "tsx src/cli.ts",
    "demo": "tsx src/cli.ts demo --fixture websocket --seed 4242 --mutant ws-drop-first-outbound",
    "proof": "tsx src/cli.ts proof",
    "campaign": "tsx src/cli.ts campaign --fixture websocket --runs 50 --clients 3 --workers 4",
    "verify": "pnpm build && pnpm check && pnpm test && pnpm test:browser",
    "package:smoke": "node scripts/package-smoke.mjs",
    "measure:yjs": "pnpm build && node scripts/measure-yjs.mjs",
    "name:check": "node scripts/check-name.mjs",
    "release:preflight": "pnpm verify && pnpm package:smoke && node scripts/release-preflight.mjs",
    "prepack": "pnpm build"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "fast-check": "^4.3.0",
    "playwright": "^1.55.0",
    "ws": "^8.18.3",
    "yjs": "^13.6.31"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.28.1",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@11.7.0",
  "license": "MIT",
  "author": "Tom Ryan",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Atomics-hub/replicafuzz.git"
  },
  "homepage": "https://github.com/Atomics-hub/replicafuzz#readme",
  "bugs": {
    "url": "https://github.com/Atomics-hub/replicafuzz/issues"
  },
  "keywords": [
    "collaboration",
    "convergence",
    "fuzz-testing",
    "local-first",
    "offline-first",
    "playwright",
    "property-testing",
    "realtime",
    "sync"
  ],
  "publishConfig": {
    "access": "public"
  }
}
